{
  "name": "todoist",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start --lan",
    "start:tunnel": "npx expo start --tunnel",
    "start:localhost": "npx expo start --localhost",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "npx expo start --web",
    "build:web": "npx expo export:web",
    "deploy:web": "npm run build:web && npx firebase deploy --only hosting",
    "firebase-login": "npx firebase login",
    "firebase-deploy": "npx firebase deploy",
    "firebase-init": "npx firebase init"
  },
  "dependencies": {
    "@expo/webpack-config": "^19.0.0",
    "@types/react": "~18.2.14",
    "expo": "^49.0.0",
    "expo-file-system": "~15.4.1",
    "expo-haptics": "~12.4.0",
    "expo-notifications": "~0.20.1",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
    "expo-updates": "~0.18.19",
    "firebase": "^12.14.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.10",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-web": "~0.19.6",
    "typescript": "^5.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@expo/ngrok": "^4.1.3",
    "babel-preset-expo": "^9.5.0",
    "eas-cli": "^20.3.0",
    "firebase-tools": "^15.19.1"
  }
}
